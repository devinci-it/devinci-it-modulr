{
    "name": "devinci-it/modulr",
    "description": "A modular, production-ready PHP UI component library inspired by GitHub Primer. Build reusable, scoped components with auto-loading CSS and JS.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "DevinciIT",
            "email": "dev@devincit.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0"
    },
    "autoload": {
        "psr-4": {
            "DevinciIT\\Modulr\\": "src/",
            "Modulr\\": "src/"
        },
        "files": [
            "src/Helpers/component.php",
            "src/Helpers/classnames.php",
            "bootstrap/helpers.php"
        ]
    },
    "keywords": [
        "ui",
        "components",
        "php",
        "modulr",
        "mvc",
        "css-scoping",
        "reusable"
    ],
    "minimum-stability": "stable"
}
